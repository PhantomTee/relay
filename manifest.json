{
    "display_information":  {
                                "name":  "RELAY",
                                "description":  "AI accountability and expert-routing layer for Slack teams.",
                                "background_color":  "#1D1C1D"
                            },
    "features":  {
                     "app_home":  {
                                      "home_tab_enabled":  true,
                                      "messages_tab_enabled":  true,
                                      "messages_tab_read_only_enabled":  false
                                  },
                     "bot_user":  {
                                      "display_name":  "RELAY",
                                      "always_online":  true
                                  },
                     "slash_commands":  [
                                            {
                                                "command":  "/relay-status",
                                                "description":  "Show your open commitments and unanswered questions.",
                                                "usage_hint":  "",
                                                "should_escape":  false
                                            },
                                            {
                                                "command":  "/relay-ask",
                                                "description":  "Ask a question and have RELAY route it to an expert.",
                                                "usage_hint":  "How do I deploy the worker?",
                                                "should_escape":  true
                                            },
                                            {
                                                "command":  "/relay-done",
                                                "description":  "Mark a RELAY commitment complete.",
                                                "usage_hint":  "commitment-id-prefix",
                                                "should_escape":  false
                                            },
                                            {
                                                "command":  "/relay-enable",
                                                "description":  "Enable RELAY in the current channel.",
                                                "usage_hint":  "",
                                                "should_escape":  false
                                            },
                                            {
                                                "command":  "/relay-disable",
                                                "description":  "Disable RELAY in the current channel.",
                                                "usage_hint":  "",
                                                "should_escape":  false
                                            },
                                            {
                                                "command":  "/relay-delete-mine",
                                                "description":  "Delete your RELAY data from the workspace database.",
                                                "usage_hint":  "",
                                                "should_escape":  false
                                            },
                                            {
                                                "command":  "/relay-purge",
                                                "description":  "Purge old completed or historical RELAY data.",
                                                "usage_hint":  "90",
                                                "should_escape":  false
                                            }
                                        ]
                 },
    "oauth_config":  {
                         "scopes":  {
                                        "bot":  [
                                                    "app_mentions:read",
                                                    "channels:history",
                                                    "channels:read",
                                                    "chat:write",
                                                    "chat:write.public",
                                                    "commands",
                                                    "groups:history",
                                                    "im:history",
                                                    "im:write",
                                                    "mpim:history",
                                                    "reactions:read",
                                                    "reactions:write",
                                                    "search:read",
                                                    "users:read",
                                                    "assistant:write"
                                                ]
                                    }
                     },
    "settings":  {
                     "event_subscriptions":  {
                                                 "bot_events":  [
                                                                    "app_home_opened",
                                                                    "message.channels",
                                                                    "message.groups",
                                                                    "message.im",
                                                                    "message.mpim",
                                                                    "assistant_thread_started",
                                                                    "assistant_thread_context_changed"
                                                                ]
                                             },
                     "interactivity":  {
                                           "is_enabled":  true
                                       },
                     "org_deploy_enabled":  false,
                     "socket_mode_enabled":  false,
                     "token_rotation_enabled":  false
                 }
}
