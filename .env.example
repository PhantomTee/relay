SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
PORT=3001

# Optional OAuth/multi-workspace install mode. If these are set, RELAY stores Slack installations in Supabase.
SLACK_CLIENT_ID=your-client-id
SLACK_CLIENT_SECRET=your-client-secret
SLACK_STATE_SECRET=replace-with-a-long-random-string
SLACK_SCOPES=app_mentions:read,assistant:write,channels:history,channels:read,chat:write,chat:write.public,commands,groups:history,im:history,im:write,mpim:history,reactions:read,reactions:write,search:read,users:read

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

GROQ_API_KEY=gsk_your_key
GROQ_MODEL=llama-3.3-70b-versatile

# Optional OpenAI-compatible embedding endpoint for semantic answer search.
EMBEDDING_API_URL=https://api.openai.com/v1/embeddings
EMBEDDING_API_KEY=sk-your-embedding-key
EMBEDDING_MODEL=text-embedding-3-small

# How long RELAY waits before routing an unanswered detected question.
QUESTION_TIMEOUT_MS=300000
CONFIDENCE_THRESHOLD=0.70
DATA_RETENTION_DAYS=90

# Set true for privacy-first workspaces where every channel must run /relay-enable.
RELAY_REQUIRE_CHANNEL_OPT_IN=false

